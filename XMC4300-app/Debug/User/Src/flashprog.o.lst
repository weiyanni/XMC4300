 540:D:/Infineon/Tools/DAVE IDE/4.5.0.202105191637/eclipse/workspace/XMC4300-app/Libraries/XMCLib/inc\xmc_fce.h **** __STATIC_INLINE void XMC_FCE_UpdateCRCCheck(const XMC_FCE_t *const engine, const uint32_t checkvalu
 541:D:/Infineon/Tools/DAVE IDE/4.5.0.202105191637/eclipse/workspace/XMC4300-app/Libraries/XMCLib/inc\xmc_fce.h **** {
 542:D:/Infineon/Tools/DAVE IDE/4.5.0.202105191637/eclipse/workspace/XMC4300-app/Libraries/XMCLib/inc\xmc_fce.h ****   engine->kernel_ptr->CHECK = 0xFACECAFEU;
 543:D:/Infineon/Tools/DAVE IDE/4.5.0.202105191637/eclipse/workspace/XMC4300-app/Libraries/XMCLib/inc\xmc_fce.h ****   engine->kernel_ptr->CHECK = checkvalue;
