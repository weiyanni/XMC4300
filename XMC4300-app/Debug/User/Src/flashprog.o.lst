  54:../User/Src/flashprog.c **** 
  55:../User/Src/flashprog.c **** /****************************************************************
  56:../User/Src/flashprog.c **** * LOCAL DATA
  57:../User/Src/flashprog.c **** ***************************************************************/
  58:../User/Src/flashprog.c **** /* * XMC4300 (256KB) 物理扇区表:
  59:../User/Src/flashprog.c ****  * Sectors 0-7:  16KB each (0x0C000000 - 0x0C01FFFF)
  60:../User/Src/flashprog.c ****  * Sector  8:    128KB     (0x0C020000 - 0x0C03FFFF)
  61:../User/Src/flashprog.c ****  */
  62:../User/Src/flashprog.c **** uint32_t* physical_sector_addresses[XMC_FLASH_SECTOR_COUNT_MAX + 1] =
  63:../User/Src/flashprog.c **** {
  64:../User/Src/flashprog.c ****   (uint32_t*)0x0C000000,  // Sector 0  (16KB) - Bootloader
  65:../User/Src/flashprog.c ****   (uint32_t*)0x0C004000,  // Sector 1  (16KB) - EEPROM
  66:../User/Src/flashprog.c ****   (uint32_t*)0x0C008000,  // Sector 2  (16KB) - Backup Start
  67:../User/Src/flashprog.c ****   (uint32_t*)0x0C00C000,  // Sector 3  (16KB)
  68:../User/Src/flashprog.c ****   (uint32_t*)0x0C010000,  // Sector 4  (16KB)
  69:../User/Src/flashprog.c ****   (uint32_t*)0x0C014000,  // Sector 5  (16KB)
  70:../User/Src/flashprog.c ****   (uint32_t*)0x0C018000,  // Sector 6  (16KB)
  71:../User/Src/flashprog.c ****   (uint32_t*)0x0C01C000,  // Sector 7  (16KB) - Backup End
  72:../User/Src/flashprog.c ****   (uint32_t*)0x0C020000,  // Sector 8  (128KB) - Application Run Area
  73:../User/Src/flashprog.c ****   (uint32_t*)0x0C040000   // End of Flash (Start of non-existent Sector 9)
  74:../User/Src/flashprog.c **** };
  75:../User/Src/flashprog.c **** 
  76:../User/Src/flashprog.c **** /* Specification to initialize FCE for CRC32 calculation*/
  77:../User/Src/flashprog.c **** static XMC_FCE_t FCE_config0 =
  78:../User/Src/flashprog.c **** {
  79:../User/Src/flashprog.c ****   .kernel_ptr    = XMC_FCE_CRC32_0,    /**< FCE Kernel Pointer */
  80:../User/Src/flashprog.c ****   .fce_cfg_update.config_xsel = true,
  81:../User/Src/flashprog.c ****   .fce_cfg_update.config_refin = true,
  82:../User/Src/flashprog.c ****   .fce_cfg_update.config_refout = true,
  83:../User/Src/flashprog.c ****   .seedvalue = 0xffffffff
  84:../User/Src/flashprog.c **** };
  85:../User/Src/flashprog.c **** 
  86:../User/Src/flashprog.c **** static uint32_t* gl_flash_write_address;
  87:../User/Src/flashprog.c **** static uint32_t* gl_flash_write_start_address;
  88:../User/Src/flashprog.c **** static uint32_t  gl_flash_bytes_written=0;
  89:../User/Src/flashprog.c **** static uint8_t   gl_flash_check_prog;
  90:../User/Src/flashprog.c **** static uint16_t  gl_flash_erased;
  91:../User/Src/flashprog.c **** static uint32_t  gl_flash_max_size=0;
  92:../User/Src/flashprog.c **** static uint8_t   gl_flash_page_prep[256];
  93:../User/Src/flashprog.c **** static uint32_t  gl_flash_page_prep_index=0;
  94:../User/Src/flashprog.c **** 
