 561:D:/Infineon/Tools/DAVE IDE/4.5.0.202105191637/eclipse/workspace/XMC4300-app/Libraries/XMCLib/inc\xmc_fce.h ****   engine->kernel_ptr->LENGTH = 0xFACECAFEU;
