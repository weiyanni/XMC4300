   1:../BSP/shared_conf.h **** #ifndef SHARED_CONF_H_
   2:../BSP/shared_conf.h **** #define SHARED_CONF_H_
   3:../BSP/shared_conf.h **** 
   4:../BSP/shared_conf.h **** #include <stdint.h>
   5:../BSP/shared_conf.h **** 
   6:../BSP/shared_conf.h **** /* ==============================================================
   7:../BSP/shared_conf.h ****  * 1. Flash 内存地图定义 (Total 256KB Flash)
   8:../BSP/shared_conf.h ****  * 
   9:../BSP/shared_conf.h ****  * XMC4300 Flash 扇区布局 (每扇区 16KB):
  10:../BSP/shared_conf.h ****  *   - S0-S5 (96KB):  Bootloader 代码
  11:../BSP/shared_conf.h ****  *   - S6-S7 (32KB):  EEPROM 仿真区域 (SharedConfig 等)
  12:../BSP/shared_conf.h ****  *   - S8    (128KB): Application 代码
  13:../BSP/shared_conf.h ****  *
  14:../BSP/shared_conf.h ****  * 地址映射:
  15:../BSP/shared_conf.h ****  *   - Cached (0x08...): 用于代码执行和数据读取
  16:../BSP/shared_conf.h ****  *   - Uncached (0x0C...): 用于 Flash 编程/擦除操作
  17:../BSP/shared_conf.h ****  * ============================================================== */
  18:../BSP/shared_conf.h **** 
  19:../BSP/shared_conf.h **** /* --- Bootloader 区域 (96KB, S0-S5) --- */
  20:../BSP/shared_conf.h **** #define BOOT_START_ADDR         0x08000000UL
  21:../BSP/shared_conf.h **** #define BOOT_START_ADDR_UC      0x0C000000UL
  22:../BSP/shared_conf.h **** #define BOOT_SIZE               0x00018000UL  // 96 KB (6 sectors * 16KB)
  23:../BSP/shared_conf.h **** #define BOOT_END_ADDR           (BOOT_START_ADDR + BOOT_SIZE - 1)
  24:../BSP/shared_conf.h **** 
  25:../BSP/shared_conf.h **** /* --- EEPROM 仿真区域 (32KB, S6-S7) --- */
  26:../BSP/shared_conf.h **** #define EEPROM_START_ADDR       0x0C018000UL  // Uncached 地址（用于写入/擦除）
  27:../BSP/shared_conf.h **** #define EEPROM_START_ADDR_RD    0x08018000UL  // Cached 地址（用于读取）
  28:../BSP/shared_conf.h **** #define EEPROM_SIZE             0x00008000UL  // 32 KB (2 sectors * 16KB)
  29:../BSP/shared_conf.h **** #define EEPROM_END_ADDR         (EEPROM_START_ADDR + EEPROM_SIZE - 1)
  30:../BSP/shared_conf.h **** 
  31:../BSP/shared_conf.h **** /* --- App 区域 (128KB, S8) --- */
  32:../BSP/shared_conf.h **** #define APP_START_ADDR          0x0C020000UL  // Uncached 地址（用于写入）
  33:../BSP/shared_conf.h **** #define APP_START_ADDR_RD       0x08020000UL  // Cached 地址（用于读取/执行）
  34:../BSP/shared_conf.h **** #define APP_MAX_SIZE            0x00020000UL  // 128 KB
  35:../BSP/shared_conf.h **** #define APP_END_ADDR            (APP_START_ADDR + APP_MAX_SIZE - 1)
  36:../BSP/shared_conf.h **** 
  37:../BSP/shared_conf.h **** /* ==============================================================
  38:../BSP/shared_conf.h ****  * 1.5. RAM 标志位 (用于区分软件复位和断电重启)
  39:../BSP/shared_conf.h ****  * 
  40:../BSP/shared_conf.h ****  * 原理：
  41:../BSP/shared_conf.h ****  *   - 软件复位 (NVIC_SystemReset): RAM 数据保留
  42:../BSP/shared_conf.h ****  *   - 断电重启: RAM 数据丢失 (变成随机值)
  43:../BSP/shared_conf.h ****  * 
  44:../BSP/shared_conf.h ****  * 使用 .noinit 段：
  45:../BSP/shared_conf.h ****  *   - 编译器自动分配地址
  46:../BSP/shared_conf.h ****  *   - 启动代码不会清零这个变量
  47:../BSP/shared_conf.h ****  *   - Boot 和 App 都必须定义这个变量（同名同段）
  48:../BSP/shared_conf.h ****  * ============================================================== */
  49:../BSP/shared_conf.h **** 
  50:../BSP/shared_conf.h **** #define RAM_MAGIC_VAL  0xB007B007UL  // "BOOTBOOT" 的数字化表示
  51:../BSP/shared_conf.h **** 
  52:../BSP/shared_conf.h **** /* 
  53:../BSP/shared_conf.h ****  * 注意：这个变量在 Boot 和 App 中都需要定义一次（不能只在头文件声明）
  54:../BSP/shared_conf.h ****  * 在各自的 main.c 或 app_init.c / boot_init.c 中添加：
  55:../BSP/shared_conf.h ****  * uint32_t g_RamMagicFlag __attribute__((section(".noinit")));
  56:../BSP/shared_conf.h ****  */
  57:../BSP/shared_conf.h **** 
  58:../BSP/shared_conf.h **** /* ==============================================================
  59:../BSP/shared_conf.h ****  * 2. SharedConfig 在 EEPROM 中的存储布局
  60:../BSP/shared_conf.h ****  * 
  61:../BSP/shared_conf.h ****  * E_EEPROM_XMC4 使用块循环计数 + CRC 方式管理数据，
  62:../BSP/shared_conf.h ****  * 我们的 SharedConfig_t (13 字节) 存储在 EEPROM 数据区的开头。
  63:../BSP/shared_conf.h ****  * 
  64:../BSP/shared_conf.h ****  * 数据块布局 (假设 DATA_BLOCK_SIZE = 2048):
  65:../BSP/shared_conf.h ****  *   - Offset 0x00:  SharedConfig_t (13 字节)
  66:../BSP/shared_conf.h ****  *   - Offset 0x10+: 其他用户数据 (可扩展)
  67:../BSP/shared_conf.h ****  * ============================================================== */
  68:../BSP/shared_conf.h **** 
  69:../BSP/shared_conf.h **** /* SharedConfig_t 在 E_EEPROM 数据区中的偏移地址 */
  70:../BSP/shared_conf.h **** /* EtherCAT SII 数据通常占用前 0x800 字节，因此我们将 SharedConfig 移到 0x1000 (4K
  71:../BSP/shared_conf.h **** #define SHARED_CONFIG_EEPROM_OFFSET    0x1000U
  72:../BSP/shared_conf.h **** 
  73:../BSP/shared_conf.h **** /* ==============================================================
  74:../BSP/shared_conf.h ****  * 3. 共享配置结构体定义
  75:../BSP/shared_conf.h ****  * ============================================================== */
  76:../BSP/shared_conf.h **** 
  77:../BSP/shared_conf.h **** #define SHARED_MAGIC_VALID      0x5AA5A55AUL  // App 有效标志
  78:../BSP/shared_conf.h **** #define SHARED_MAGIC_UPDATING   0xEEEEEEEEUL  // 正在升级/损坏状态
  79:../BSP/shared_conf.h **** 
  80:../BSP/shared_conf.h **** typedef struct {
  81:../BSP/shared_conf.h ****     uint32_t MagicHeader;       // 0x00: VALID, REQUEST, 或 0xFFFFFFFF
  82:../BSP/shared_conf.h ****     uint32_t AppActualSize;     // 0x04: App 实际大小
  83:../BSP/shared_conf.h ****     uint32_t AppCRC32;          // 0x08: CRC32 校验值
  84:../BSP/shared_conf.h ****     uint8_t  Checksum;          // 0x0C: 前面所有字节的 8 位累加和
  85:../BSP/shared_conf.h **** } __attribute__((packed)) SharedConfig_t;
  86:../BSP/shared_conf.h **** 
  87:../BSP/shared_conf.h **** /* 计算校验和 (不包含 Checksum 字段本身) */
