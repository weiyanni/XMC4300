 408:../SSC/Src/coeappl.c **** /**
 409:../SSC/Src/coeappl.c ****  * \brief 0x1C00 (Sync manager type) variable to handle the object data
 410:../SSC/Src/coeappl.c ****  *
 411:../SSC/Src/coeappl.c ****  * SI 0 : 4 (4 SyncManagers available)
 412:../SSC/Src/coeappl.c ****  * SI1 (SM0): Mailbox Out (0x1)
 413:../SSC/Src/coeappl.c ****  * SI2 (SM1): Mailbox In (0x2)
 414:../SSC/Src/coeappl.c ****  * SI3 (SM2): Process data Out (0x3)
 415:../SSC/Src/coeappl.c ****  * SI4 (SM3): Process data In (0x4)
 416:../SSC/Src/coeappl.c ****  *
 417:../SSC/Src/coeappl.c ****  */
 418:../SSC/Src/coeappl.c ****  /*ECATCHANGE_START(V5.13)*/
 419:../SSC/Src/coeappl.c **** TOBJ1C00 sSyncmanagertype = {0x04, {0x0201, 0x0403}};
 420:../SSC/Src/coeappl.c **** /*ECATCHANGE_END(V5.13)*/
 421:../SSC/Src/coeappl.c **** 
 422:../SSC/Src/coeappl.c **** 
